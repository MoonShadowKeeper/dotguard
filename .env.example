# Database
# @type url
# @required
# @description PostgreSQL connection string
DATABASE_URL=postgres://localhost:5432/mydb

# @type port
# @required
# @min 1024
# @max 65535
PORT=3000

# @type email
# @required
API_CONTACT=admin@example.com

# @type boolean
# @optional
DEBUG=true

# @type enum(development,staging,production)
# @required
NODE_ENV=development

# @type string
# @optional
# @pattern ^sk_
API_KEY=
